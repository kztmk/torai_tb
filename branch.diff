diff --git a/src/utils/firstMonthDiscount.ts b/src/utils/firstMonthDiscount.ts
new file mode 100644
index 0000000..2665ada
--- /dev/null
+++ b/src/utils/firstMonthDiscount.ts
@@ -0,0 +1,38 @@
+import { Timestamp } from 'firebase/firestore/lite';
+
+export const FIRST_MONTH_DISCOUNT_CURRENCY = 'jpy';
+export const FIRST_MONTH_DISCOUNT_VALID_DAYS = 1;
+export const FIRST_MONTH_DISCOUNT_AMOUNT_BY_PLAN_ID: Record<string, number> = {
+  basic_monthly: 500,
+  half_yearly: 1000,
+  yearly: 2000,
+};
+export const BANK_TRANSFER_FEE_AMOUNT = 880;
+
+export const getFirstMonthDiscountAmountOff = (planId?: string | null): number | null => {
+  if (!planId) {
+    return null;
+  }
+  return FIRST_MONTH_DISCOUNT_AMOUNT_BY_PLAN_ID[planId] ?? null;
+};
+
+export const formatFirstMonthDiscountAmount = (planId?: string | null): string => {
+  const amountOff = getFirstMonthDiscountAmountOff(planId);
+  return amountOff ? `${amountOff.toLocaleString()}円` : '対象プランごとの金額';
+};
+
+export const getFirstMonthDiscountExpiresAt = (): Timestamp => {
+  const expiresAt = new Date();
+  expiresAt.setDate(expiresAt.getDate() + FIRST_MONTH_DISCOUNT_VALID_DAYS);
+  return Timestamp.fromDate(expiresAt);
+};
+
+export const isFirstMonthDiscountActive = (expiresAt?: string | null): boolean => {
+  if (!expiresAt) {
+    return false;
+  }
+  return new Date(expiresAt).getTime() > Date.now();
+};
+
+export const formatBankTransferFeeDiscountAmount = (): string =>
+  `${BANK_TRANSFER_FEE_AMOUNT.toLocaleString()}円`;
diff --git a/src/utils/gasProxyClient.ts b/src/utils/gasProxyClient.ts
new file mode 100644
index 0000000..6c03eb2
--- /dev/null
+++ b/src/utils/gasProxyClient.ts
@@ -0,0 +1,34 @@
+import axios, { AxiosRequestConfig } from 'axios';
+import { auth } from '@/firebase';
+
+export const GAS_PROXY_ENDPOINT = import.meta.env.VITE_PROXY_URL || '/api/gas-proxy';
+
+type GasProxyParams = {
+  action: string;
+  target: string;
+  [key: string]: string | number | boolean | undefined;
+};
+
+export const gasProxyPost = async <TBody = unknown>(
+  body: TBody,
+  params: GasProxyParams,
+  config: AxiosRequestConfig = {}
+) => {
+  const token = await auth.currentUser?.getIdToken();
+  if (!token) {
+    throw new Error('ユーザー認証が必要です。');
+  }
+
+  return axios.post(GAS_PROXY_ENDPOINT, body, {
+    ...config,
